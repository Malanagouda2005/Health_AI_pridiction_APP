# Database Configuration
# Use SQLite (default): sqlite:///health_ai.db
# Use PostgreSQL: postgresql://user:password@localhost:5432/health_ai
# Use MySQL: mysql+pymysql://user:password@localhost:3306/health_ai
DATABASE_URL=sqlite:///health_ai.db

# Secret Key (change this in production!)
SECRET_KEY=your-secret-key-change-this-in-production

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# CORS settings
FLASK_CORS_ORIGINS=*

# Model paths (relative to project root)
MODEL_DIR=.
# use proper data sets
